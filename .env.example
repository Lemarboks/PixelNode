# PixelNode — environment variables
# Copy to `.env` for local `vercel dev`, and set the same keys in the Vercel
# dashboard (Project → Settings → Environment Variables) for production.
# NEVER commit real values. This file holds placeholders only.

# --- Supabase (server-side) ---
# Dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
# Use the SERVICE ROLE key (bypasses RLS). Keep secret — server-only.
SUPABASE_SERVICE_KEY=your-service-role-key

# --- Resend (transactional email) ---
# https://resend.com → API Keys
RESEND_API_KEY=re_your_api_key
# Verified sender, e.g. "PixelNode <hello@yourdomain.com>"
LEAD_FROM_EMAIL=PixelNode <hello@yourdomain.com>
# Inbox where you receive new leads
LEAD_TO_EMAIL=pixelnode.studio@gmail.com

# --- Admin dashboard (/admin) ---
# Password you type to log into /admin. Choose something strong.
ADMIN_PASSWORD=change-me-to-a-strong-password
# Secret used to sign the admin session cookie. Must be >= 32 chars.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
ADMIN_JWT_SECRET=generate-a-long-random-string
